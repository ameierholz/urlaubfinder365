{
  "expo": {
    "name": "Urlaubfinder365",
    "slug": "urlaubfinder365",
    "version": "1.0.0",
    "scheme": "urlaubfinder365",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1db682"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "de.urlaubfinder365.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Wird für die Reisekarte und nahegelegene Reiseziele verwendet."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1db682"
      },
      "package": "de.urlaubfinder365.app",
      "permissions": ["ACCESS_FINE_LOCATION"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1db682"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
