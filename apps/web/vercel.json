{
  "framework": "nextjs",
  "installCommand": "pnpm install --shamefully-hoist",
  "buildCommand": "pnpm build",
  "outputDirectory": ".next",
  "regions": ["fra1"],
  "crons": [
    {
      "path": "/api/cron/collect-prices?profile=pauschal",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/collect-prices?profile=hotel",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/collect-prices?profile=ai",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/collect-prices?profile=last_minute",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/anbieter-monatsbericht",
      "schedule": "0 8 1 * *"
    },
    {
      "path": "/api/cron/buchung-erinnerung",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/buchung-bewertung",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/buchung-abschliessen",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/sync-travel-warnings",
      "schedule": "0 7 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
