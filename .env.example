# ─────────────────────────────────────────────────────────────────
# Urlaubfinder365 — Umgebungsvariablen (Template)
# ─────────────────────────────────────────────────────────────────
# Kopiere diese Datei nach .env.local und trage die echten Werte ein.
# ─────────────────────────────────────────────────────────────────

# ── Supabase (https://supabase.com/dashboard → Settings → API) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Firebase (nur Push Notifications) ────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
FIREBASE_SERVER_KEY=

# ── Reise-API (api.specials.de) ──────────────────────────────────
NEXT_PUBLIC_TRAVEL_API_BASE=https://api.specials.de/package/teaser.json
NEXT_PUBLIC_TRAVEL_AGENT_ID=

# ── Cron-Schutz ──────────────────────────────────────────────────
CRON_SECRET=

# ── Site ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://urlaubfinder365.de
